# U&V Platform — Environment Variables
# Copy to .env and fill in real values for local development.

NODE_ENV=development

# Database
DATABASE_URL=postgresql://uandv:uandv_dev_password@localhost:5432/uandv?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000

# Clerk
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=info@uandv.com
# WhatsApp deep link only — do not display phone digits in UI copy
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/919688884554
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/uandvi
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Logging / throttle
LOG_LEVEL=info
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
