# U&V Platform — Environment Variables
# Copy to .env and fill in real values for local development.
# Never commit real secrets.

NODE_ENV=development

# Database
DATABASE_URL=postgresql://uandv:uandv_dev_password@localhost:5432/uandv?schema=public

# Redis (API / worker)
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000

# Clerk
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Resend (web contact / enquiry emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=U&V Technologies <onboarding@resend.dev>
CONTACT_TO_EMAIL=info@uandv.com

# Public site
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=info@uandv.com
NEXT_PUBLIC_CONTACT_EMAIL_SECONDARY=uandv.com@gmail.com
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/919688884554
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/uandvi

# Logging / throttle
LOG_LEVEL=info
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
